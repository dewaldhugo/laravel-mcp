{
    "name": "dewaldhugo/laravel-mcp",
    "description": "Local Model Context Protocol (MCP) Server for Laravel AI Architecture",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Dewald Hugo"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "*",
        "illuminate/support": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "DewaldHugo\\LaravelMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DewaldHugo\\LaravelMcp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DewaldHugo\\LaravelMcp\\McpServiceProvider"
            ]
        }
    }
}