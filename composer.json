{
    "name": "dewaldhugo/laravel-mcp",
    "description": "Local Model Context Protocol (MCP) Server for Laravel AI Architecture",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Dewald Hugo",
            "email": "dewaldhugo@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "*",
        "illuminate/support": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.25"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": {
            "DewaldHugo\\LaravelMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DewaldHugo\\LaravelMcp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DewaldHugo\\LaravelMcp\\McpServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}